PROMETHEUS_URL=https://prometheus.dev-sachin.co.uk
RL_AGENT_URL=http://localhost:5000    #https://rl-agent.dev-sachin.co.uk/     
NAMESPACE=
LABEL_SELECTOR=rl-autoscale=true

INTERVAL=15s
MIN_REPLICAS=1
MAX_REPLICAS=10
MAX_SCALE_STEP=1
COOLDOWN=30s
CONFIDENCE_MIN=0.10
TRAINING_MODE=true
MOCK_MODE=false
PROM_TIMEOUT=5s
RL_TIMEOUT=15s




# Activated automatically when RL agent is unreachable or circuit breaker opens.
# Set FALLBACK_ENABLED=false to restore original no-op behaviour.
FALLBACK_ENABLED=true

# Scale-UP triggers — any ONE metric exceeding its threshold → scale_up
FALLBACK_SCALEUP_CPU=0.75        # scale up when CPU > 75%
FALLBACK_SCALEUP_LATENCY=0.50    # scale up when P95 latency > 500ms
FALLBACK_SCALEUP_ERROR=0.05      # scale up when error rate > 5%
FALLBACK_SCALEUP_REQRATE=100.0   # scale up when req/s > 100  (0 = disabled)

# Scale-DOWN triggers — ALL THREE must be below threshold simultaneously → scale_down
FALLBACK_SCALEDOWN_CPU=0.20      # scale down only when CPU < 20%
FALLBACK_SCALEDOWN_LATENCY=0.10  # scale down only when P95 < 100ms
FALLBACK_SCALEDOWN_ERROR=0.01    # scale down only when error rate < 1%