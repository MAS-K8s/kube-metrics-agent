PROMETHEUS_URL=http://34.82.117.119:30457
RL_AGENT_URL=http://127.0.0.1:5000
NAMESPACE=
LABEL_SELECTOR=rl-autoscale=true

INTERVAL=30s
MIN_REPLICAS=1
MAX_REPLICAS=10
MAX_SCALE_STEP=1
# FIX: Was 30s — fine for scale-up, but after scale-down the 30s cooldown
# prevented follow-up scale-ups during the load ramp.  Keep at 30s.
COOLDOWN=30s

# FIX: Pre-training now uses real metric ranges so confidence starts ~40-55%.
# But to be safe during the first few live training steps, keep this at 0.15
# so the agent can act and collect real rewards.
# Raise to 0.40 after you see confidence consistently above 50% in the logs
# (usually after ~5-10 real training steps with the fixed reward function).
CONFIDENCE_MIN=0.15

TRAINING_MODE=true

MOCK_MODE=false

PROM_TIMEOUT=10s

# FIX: Flask/PyTorch cold start can take 6-8s.  15s gives headroom.
RL_TIMEOUT=15s