PROMETHEUS_URL=https://prometheus.dev-sachin.co.uk
RL_AGENT_URL=  http://localhost:5000    #https://rl-agent.dev-sachin.co.uk/     
NAMESPACE=
LABEL_SELECTOR=rl-autoscale=true

INTERVAL=15s
MIN_REPLICAS=1
MAX_REPLICAS=10
MAX_SCALE_STEP=1
COOLDOWN=30s
CONFIDENCE_MIN=0.10
TRAINING_MODE=true
MOCK_MODE=false
PROM_TIMEOUT=5s
RL_TIMEOUT=15s